---
import '../styles/global.css';

const stats = [
  {
    num: "6%",
    label: "conversion lift via PayPal/Braintree experiments at MasterClass"
  },
  {
    num: "23×",
    label: "faster page load on SEO pages — 5.3s down to 233ms"
  },
  {
    num: "17%",
    label: "conversion lift from category carousel feature"
  }
];

const work = [
  {
    company: "Signalfire",
    years: "2026–present",
    role: "Co-founder & Engineer",
    detail: "Turns physical public spaces into discovery points for community groups. A QR-coded totem marks where a group meets — scanning it opens a location-specific bulletin board with events, recurring meetups, and links to join. Full-stack web app with native iOS and Android clients (not yet publicly available), piloting in St. Petersburg, FL.",
    link: { href: "https://signalfire.live/about", label: "signalfire.live" },
    tags: ["Rails", "React", "iOS", "Android", "Full-stack"]
  },
  {
    company: "MasterClass",
    years: "2016–2020",
    role: "Software Engineer → Senior Software Engineer I",
    detail: "Led backend engineering for pricing and referral experiments — among the most critical business work that year. Built PayPal/Braintree subscription integrations (<strong>+6% conversion</strong>). Reduced SEO page load time from <strong>5.3s → 233ms</strong>, cutting bounce rate significantly.",
    tags: ["Rails", "PostgreSQL", "GraphQL", "React", "A/B testing"]
  },
  {
    company: "Emeritus",
    years: "2020–2022",
    role: "Senior Software Engineer",
    detail: "Rearchitected the entire payments system to reduce Salesforce dependency and enable new functionality. Designed multi-currency support and a Multi-Armed Bandit testing framework from scratch.",
    tags: ["Rails", "Payments", "MAB testing", "Multi-currency"]
  },
  {
    company: "Secureframe",
    years: "2022–2023",
    role: "Senior Software Engineer",
    detail: "Built and maintained compliance automation integrations (Google, AWS, Microsoft). Created a production data replication and anonymization tool to improve debugging and environment consistency while protecting PII.",
    tags: ["Rails", "Compliance automation", "AWS", "Data tooling"]
  }
];

const services = [
  {
    title: "Full-stack web development",
    desc: "End-to-end Rails APIs and React frontends. New products, new features, or rescuing existing codebases."
  },
  {
    title: "Mobile apps",
    desc: "React Native for iOS and Android. Shared codebase, native feel, shipped to both stores."
  },
  {
    title: "Payments & billing systems",
    desc: "Stripe, Braintree, multi-currency. I've rearchitected payment systems at scale."
  },
  {
    title: "API & backend development",
    desc: "Greenfield Rails APIs, third-party integrations, and backend features. Clean, tested, documented."
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Full-stack contractor based in St. Pete, FL. 7+ years building and scaling production systems at high-growth SaaS companies. Web, mobile, payments, and more." />
    <title>Fuzz Worley — Full-Stack Contractor</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <div class="container">

      <!-- Nav -->
      <div class="nav-wrapper">
      <nav class="nav">
        <a class="nav-logo" href="/">Fuzz Worley</a>
        <div class="nav-links">
          <a class="nav-link" href="#work">Work</a>
          <a class="nav-link" href="#services">Services</a>
          <a class="nav-cta" href="#contact">Get in touch</a>
        </div>
      </nav>
      </div>

      <!-- Hero + Stats -->
      <div class="above-fold">
        <section class="hero">
          <p class="eyebrow">Full-stack contractor · St. Pete, FL · Available now</p>
          <h1 class="hero-headline">
            Senior engineer for <em>SaaS teams that need it done right</em>
          </h1>
          <p class="hero-sub">
            I've shipped payments systems, compliance automation, and growth experiments
            at MasterClass, Secureframe, and Emeritus. 7+ years building and scaling
            production systems at high-growth SaaS companies.
          </p>
          <div class="hero-actions">
            <a class="btn-primary" href="#contact">Work with me</a>
            <a class="btn-ghost" href="#work">See my work ↓</a>
          </div>
        </section>

        <div class="stats-row">
          {stats.map(s => (
            <div class="stat">
              <div class="stat-num">{s.num}</div>
              <div class="stat-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Work -->
      <section id="work">
        <p class="section-label">Selected work</p>
        <div class="work-list">
          {work.map(w => (
            <div class="work-item">
              <div class="work-meta">
                <span class="work-company">{w.company}</span>
                <span class="work-years">{w.years}</span>
              </div>
              <div class="work-role">{w.role}</div>
              <div class="work-detail" set:html={w.detail} />
              {w.link && <a class="work-link" href={w.link.href} target="_blank" rel="noopener">{w.link.label} ↗</a>}
              <div class="tags">
                {w.tags.map(t => <span class="tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Services -->
      <section id="services">
        <p class="section-label">Services</p>
        <div class="services-grid">
          {services.map(s => (
            <div class="service-card">
              <div class="service-title">{s.title}</div>
              <div class="service-desc">{s.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Fintech banner -->
      <div class="fintech-banner">
        <div class="fintech-icon">₿</div>
        <div>
          <div class="fintech-title">Fintech & crypto background</div>
          <div class="fintech-desc">
            Founded Bitcopia in 2012 — one of the first bitcoin brokerages — handling hundreds of orders per day with zero loss of funds.
            I understand the security, compliance, and reliability requirements of financial
            systems firsthand. Useful for crypto exchanges, payment processors, and
            fintech startups.
          </div>
        </div>
      </div>

      <!-- CTA / Contact -->
      <section id="contact" class="cta-section">
        <h2 class="cta-headline">Let's build something together</h2>
        <p class="cta-sub">
          Drop me a line with what you're working on.<br />
          I'll get back to you within one business day.
        </p>
        <form class="contact-form" action="https://formspree.io/f/xeenjvap" method="POST">
          <input type="email" name="email" placeholder="your@email.com" required />
          <textarea name="message" placeholder="What are you working on?" rows="4" required></textarea>
          <button type="submit" class="btn-primary">Send message</button>
        </form>
        <p class="contact-alt">Or email me directly at <a href="mailto:hello@fuzzworley.dev">hello@fuzzworley.dev</a></p>
      </section>

      <!-- Footer -->
      <footer class="footer">
        <span class="footer-name">fuzzworley.dev</span>
        <div class="footer-links">
          <a class="footer-link" href="https://linkedin.com/in/stevenworley" target="_blank" rel="noopener">LinkedIn</a>
          <a class="footer-link" href="https://github.com/fuzzworley" target="_blank" rel="noopener">GitHub</a>
        </div>
      </footer>

    </div>
  </body>
</html>
